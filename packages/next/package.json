{
  "name": "@tenantscale/next",
  "version": "0.0.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "@tenantscale/sdk": "workspace:*",
    "next": "^14.0.0 || ^15.0.0"
  },
  "dependencies": {
    "@tenantscale/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "next": "^16.2.11",
    "next-test-api-route-handler": "^4.0.1",
    "typescript": "^7.0.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TenantScale/sdk.git"
  }
}
