{
  "name": "@tenantscale/sdk",
  "version": "0.4.0",
  "description": "Framework-agnostic multi-tenant SDK for B2B SaaS — tenant isolation, audit logging, plan enforcement, and API key management.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.6",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "7.0.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TenantScale/sdk.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "multi-tenant",
    "saas",
    "tenant-isolation",
    "b2b",
    "supabase"
  ],
  "publishConfig": {
    "access": "public"
  }
}
